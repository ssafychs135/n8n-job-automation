    {
      "parameters": {
        "jsCode": "// 방금 조회한 done 공고들을 notified 처리 (전송 후 실행).\nconst rows = $('미전송 done 조회').all();\nconst ids = rows.map(r => r.json.id).filter(v => v != null);\nif (ids.length === 0) return [];\nreturn [{ json: { sql: `UPDATE jobs SET notified_at=now() WHERE id IN (${ids.join(',')});` } }];"
      },
