    {
      "parameters": {
        "jsCode": "// done인데 아직 안 보낸 공고를 디스코드 임베드 카드로 만든다(10개씩 묶음).\nconst rows = $('미전송 done 조회').all();\nif (rows.length === 0) return [];\nconst today = new Date().toISOString().slice(0, 10);\n\nconst embeds = rows.map(it => {\n  const m = it.json;\n  let desc = (m.summary || '').replace(/\\n?기술스택\\s*[:：].*$/m, '').trim();\n  if (desc.length > 400) desc = desc.slice(0, 400) + '…';\n  const stacks = Array.isArray(m.tech_stacks) ? m.tech_stacks.join(', ') : (m.tech_stacks || '');\n  const career = [m.min_career, m.max_career].filter(v => v != null).join('~') || '무관';\n  return {\n    title: `${m.company} — ${m.title}`.slice(0, 250),\n    url: m.url, color: 5814783,\n    description: desc || '(요약 없음)',\n    fields: [\n      { name: '경력', value: String(career), inline: true },\n      { name: '기술스택', value: (stacks || '-').slice(0, 1000), inline: true },\n      { name: '출처', value: String(m.source), inline: true },\n    ],\n  };\n});\n\nconst out = [];\nfor (let i = 0; i < embeds.length; i += 10) {\n  const item = { embeds: embeds.slice(i, i + 10) };\n  if (i === 0) item.content = `📋 **새 채용 공고 ${embeds.length}건** (${today})`;\n  out.push({ json: item });\n}\nreturn out;"
      },
      "id": "ffab9262-a376-45a3-85b0-691b0e0c0626",
      "name": "임베드 생성",
