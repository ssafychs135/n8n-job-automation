        "operation": "executeQuery",
        "query": "=SELECT id, source, job_id, company, title, url, min_career, max_career, tech_stacks, summary FROM jobs WHERE status='done' AND notified_at IS NULL ORDER BY collected_at LIMIT {{ $json.notifyBatchSize }}",
        "options": {}
      },
      "id": "8f985daa-dea1-4ed0-b8af-6ae26b7e7500",
      "name": "미전송 done 조회",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.6,
      "position": [
        -32,
        448
