      "id": "b7167324-f550-482e-8321-88a671e88773",
      "name": "상세 조회",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        660,
        300
      ],
      "onError": "continueRegularOutput",
      "retryOnFail": true,
      "maxTries": 2,
      "waitBetweenTries": 1000
    },
    {
      "parameters": {
        "jsCode": "// pending 배치의 상세를 파싱해 요약 프롬프트 생성. (연차 필터는 수집기로 이동됨)\n// [All Items] SELECT 결과(rows)와 상세조회($input)를 인덱스로 짝짓는다.\nconst rows = $('pending 배치 조회').all();\nconst details = $input.all();\nconst out = [];\nfor (let i = 0; i < rows.length; i++) {\n  const r = rows[i].json;\n  const d = details[i]?.json || {};\n  let responsibility = '', qualifications = '', preferred = '', ok = true;\n  if (d.result) {\n    responsibility = d.result.responsibility || '';\n    qualifications = d.result.qualifications || '';\n    preferred      = d.result.preferredRequirements || '';\n  } else if (d.data?.job?.detail) {\n    const det = d.data.job.detail;\n    responsibility = det.main_tasks || det.intro || '';\n    qualifications = det.requirements || '';\n    preferred      = det.preferred_points || '';\n  } else { ok = false; }                  // 상세 파싱 실패 → fail\n\n  const action = ok ? 'summarize' : 'fail';\n  const prompt = `제목: ${r.title}\\n회사: ${r.company}\\n\\n[주요업무]\\n${responsibility}\\n\\n[자격요건]\\n${qualifications}\\n\\n[우대사항]\\n${preferred}`;\n  out.push({ json: { id: r.id, source: r.source, job_id: r.job_id, company: r.company, title: r.title, url: r.url, attempts: r.attempts, action, prompt } });\n}\nreturn out;"
      },
      "id": "580ea71c-a30b-4c92-a161-d7e93bfe1640",
      "name": "처리 준비",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        880,
        300
      ]
    },
    {
