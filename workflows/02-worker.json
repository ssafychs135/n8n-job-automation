    {
      "parameters": {
        "method": "POST",
        "url": "http://host.docker.internal:1234/v1/chat/completions",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "User-Agent",
              "value": "Mozilla/5.0"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ model: $('설정 (Config)').first().json.model, messages: [ { role: 'system', content: '너는 채용공고를 3줄로 요약하고 핵심 자격요건을 뽑는 도우미다. 답변의 맨 마지막 줄에 반드시 \\'기술스택: 키워드1, 키워드2\\' 형식으로 공고에 등장한 기술 스택을 쉼표로 구분해 나열하라.' }, { role: 'user', content: $json.prompt } ], temperature: 0.3, max_tokens: 800, tools: [] }) }}",
        "options": {}
      },
      "id": "abadd019-71a8-4e19-9994-2f1ad8475525",
      "name": "AI 요약 (LM Studio)",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        1320,
        180
      ],
      "onError": "continueRegularOutput"
    },
    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "// 요약 성공 → done UPDATE, 실패(빈 응답) → 재시도 캡. [Each Item]\n// (연차/기술스택은 수집 단계에서 이미 저장됨. 요약에서 기술스택 보완만.)\nconst m = $('처리 준비').item.json;\nconst content = $json.choices?.[0]?.message?.content;\nconst esc = (v) => v == null ? 'NULL' : `'${String(v).replace(/'/g, \"''\")}'`;\nconst arr = (list) => { const a = (list || []).map(s => `'${String(s).replace(/'/g, \"''\")}'`); return a.length ? `ARRAY[${a.join(',')}]::text[]` : `'{}'::text[]`; };\nlet sql;\nif (content) {\n  let stacks = []; const mm = content.match(/기술스택\\s*[:：]\\s*(.+)/);\n  if (mm) stacks = mm[1].split(/[,·]/).map(s => s.trim()).filter(Boolean);\n  // 수집 때 채운 tech_stacks가 있으면 유지, 없으면(원티드 등) 요약에서 추출한 것으로\n  sql = `UPDATE jobs SET status='done', summary=${esc(content)}, tech_stacks=CASE WHEN cardinality(tech_stacks)>0 THEN tech_stacks ELSE ${arr(stacks)} END, attempts=attempts+1, updated_at=now() WHERE source=${esc(m.source)} AND job_id=${esc(m.job_id)};`;\n} else {\n  const maxAtt = Number($('설정 (Config)').first().json.maxAttempts) || 3;\n  sql = `UPDATE jobs SET status=CASE WHEN attempts+1 >= ${maxAtt} THEN 'failed' ELSE 'pending' END, attempts=attempts+1, updated_at=now() WHERE source=${esc(m.source)} AND job_id=${esc(m.job_id)};`;\n}\nreturn { json: { sql } };"
      },
