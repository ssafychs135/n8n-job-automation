    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "// skip(연차제외) → 'skipped', fail(상세실패) → 재시도 캡. [Each Item]\nconst m = $json;\nconst esc = (v) => v == null ? 'NULL' : `'${String(v).replace(/'/g, \"''\")}'`;\nconst maxAtt = Number($('설정 (Config)').first().json.maxAttempts) || 3;\nlet sql;\nif (m.action === 'skip') {\n  sql = `UPDATE jobs SET status='skipped', attempts=attempts+1, updated_at=now() WHERE source=${esc(m.source)} AND job_id=${esc(m.job_id)};`;\n} else {\n  sql = `UPDATE jobs SET status=CASE WHEN attempts+1 >= ${maxAtt} THEN 'failed' ELSE 'pending' END, attempts=attempts+1, updated_at=now() WHERE source=${esc(m.source)} AND job_id=${esc(m.job_id)};`;\n}\nreturn { json: { sql } };"
      },
