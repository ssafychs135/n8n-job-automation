# 이 파일을 .env 로 복사해서 사용: cp .env.example .env
# docker-compose.yml 이 여기 값들을 읽어 컨테이너 환경변수로 주입한다.

# 타임존(스케줄 cron이 한국 시간 기준으로 동작하도록)
GENERIC_TIMEZONE=Asia/Seoul
TZ=Asia/Seoul

# n8n이 인식할 호스트/포트 (로컬 접속: http://localhost:5678)
N8N_HOST=localhost
N8N_PORT=5678

# HTTPS 없이 http://localhost 로 로그인 허용(로컬 개발 전용).
# 실제 배포 시에는 HTTPS 구성 후 true 로 변경할 것.
N8N_SECURE_COOKIE=false

# --- PostgreSQL (수집 공고 저장·중복관리·통계) ---
POSTGRES_USER=n8n
POSTGRES_PASSWORD=change_me_please
POSTGRES_DB=jobs
# n8n에서 Postgres 자격증명 생성 시:
#   Host: postgres  (도커 서비스명), Port: 5432, Database: jobs (=POSTGRES_DB),
#   User/Password: 위 값. SSL: disable.

# --- LLM 접속 정보 (참고용 메모, n8n 노드에서 직접 입력) ---
# LM Studio (호스트에서 실행): http://host.docker.internal:1234/v1
# 모델: kanana-1.5-8b-instruct-2505-mlx (LM Studio에 로드된 이름과 일치시킬 것)
# API 키는 임의 값이면 통과됨(로컬 서버라 인증 안 함).
